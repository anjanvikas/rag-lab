# ── Core API Keys ────────────────────────────────────────────
# Per-user Anthropic keys are stored encrypted in rag_users.db
ANTHROPIC_API_KEY=sk-ant-api03-placeholder-text-here

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-placeholder-secret

# ── Session & Encryption ──────────────────────────────────────
# Generate these using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=placeholder-32-byte-hex-string
# Fernet key for user API key encryption
ENCRYPTION_KEY=VynW4placeholder-fernet-key-li5k=

# ── Qdrant (Docker: docker compose up qdrant -d) ─────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=papers-v1

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Embedding / Retrieval ─────────────────────────────────────
EMBED_MODEL=BAAI/bge-small-en-v1.5
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CHROMA_PATH=./chroma_db
COLLECTION_NAME=arxiv_papers

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ── Arize Phoenix ─────────────────────────────────────────────
PHOENIX_ENDPOINT=http://localhost:4318
ARIZE_API_KEY=ak-placeholder-arize-key
ARIZE_SPACE_ID=placeholder-space-id

# ── Langfuse Observability ───────────────────────────────────
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder-public-key
LANGFUSE_SECRET_KEY=sk-lf-placeholder-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── App Metadata ─────────────────────────────────────────────
ENVIRONMENT=development
